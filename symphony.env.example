# Copy to a private shell/env manager, do not commit real secrets.

# Required by Symphony to poll Linear.
# Create one in Linear: Settings -> Security & access -> Personal API keys.
LINEAR_API_KEY=lin_api_xxx

# Required for team-local separation. This is not a secret key.
# Use "me" so each local Symphony only handles issues assigned to the Linear user
# represented by that person's own LINEAR_API_KEY.
LINEAR_ASSIGNEE=me

# Optional: used by the workflow prompt for graph-context instructions.
# Keep the token value private if this URL includes a local access token.
UNDERSTAND_ANYTHING_URL=http://127.0.0.1:5173/?token=replace-with-local-token

# Optional: where Symphony creates per-issue workspaces.
SYMPHONY_WORKSPACE_ROOT=/Users/so2/workspace-so2/foundary/.local/symphony-workspaces
