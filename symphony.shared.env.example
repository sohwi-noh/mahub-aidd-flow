# Copy to symphony.shared.env on the shared development server.
# Do not commit real secrets.

# Use a dedicated Linear bot/service account key for the shared Symphony server.
LINEAR_API_KEY=lin_api_aidd_bot_xxx

# Leave LINEAR_ASSIGNEE unset for shared queue mode.
# In shared mode, Symphony processes every issue in WORKFLOW.md active_states.
# LINEAR_ASSIGNEE=

# Optional: used by the workflow prompt for graph-context instructions.
UNDERSTAND_ANYTHING_URL=http://127.0.0.1:5173/?token=replace-with-local-token

# Shared server workspace root. Override to the actual server path.
SYMPHONY_WORKSPACE_ROOT=/srv/foundary/.local/symphony-workspaces

# Shared dashboard port.
SYMPHONY_PORT=4100
